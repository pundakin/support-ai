# === Database ===
DATABASE_URL=postgresql+asyncpg://support:support_pass@localhost:5432/support_db

# Individual components (optional, for convenience)
DB_USER=support
DB_PASSWORD=support_pass
DB_NAME=support_db
DB_HOST=localhost
DB_PORT=5432

# === Ollama / LLM ===
OLLAMA_BASE_URL=http://localhost:11434

# Model for response generation
LLM_MODEL=llama3.1:latest

# Generation temperature
LLM_TEMPERATURE=0.1

# Maximum number of tokens in model response
LLM_MAX_TOKENS=2048

# === LangSmith (monitoring and tracing) ===
LANGSMITH_TRACING=true

# API key for authentication in LangSmith
LANGSMITH_API_KEY=

# Project name in LangSmith dashboard
LANGSMITH_PROJECT=support-ai

# Workspace in LangSmith
LANGSMITH_WORKSPACE_ID=

# Endpoint for connecting to LangSmith
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# === Application ===
# Host and port for Uvicorn (web server)
APP_HOST=0.0.0.0
APP_PORT=8000

# Launch mode: dev (with auto-reload) or prod
APP_ENV=dev

# Secret key for signing tokens and sessions
# Generate a secure value:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-prod

# === Telegram (alerts for critical tickets) ===
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID of user/channel for receiving notifications
# Get via @userinfobot
TELEGRAM_CHAT_ID=

# Priority threshold for sending alerts (critical/high/medium/low)
ALERT_PRIORITY_THRESHOLD=critical

# === Security ===
# Allowed origins for CORS
# Format: comma-separated, no spaces
CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

# Request limit per minute per user (rate limiting)
RATE_LIMIT_PER_MINUTE=60